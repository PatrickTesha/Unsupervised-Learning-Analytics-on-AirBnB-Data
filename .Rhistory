plot_som_heatmap <- function(model, variable_data, title_name) {
node_means <- aggregate(data_scaled, by = list(model$unit.classif), FUN = mean, na.rm = TRUE)$x
plot(model, type = "property",
property = node_means,
main = title_name,
palette.name = viridis, # High-contrast color scale
border = "grey")
}
View(PCA_results)
par(mfrow = c(2, 2)) # View all 4 themes at once
plot_som_heatmap(SOM_model, PCA_results$x[,1], "Theme 1: Availability")
plot_som_heatmap <- function(model, variable_data, title_name) {
# Calculate the mean value for each node
# We use as.numeric to strip any remaining data frame structures
node_means <- aggregate(as.numeric(variable_data),
by = list(model$unit.classif),
FUN = mean,
na.rm = TRUE)
# node_means[,1] is the Group ID (the node number)
# node_means[,2] is the actual averaged PC score
plot(model,
type = "property",
property = node_means[, 2],
main = title_name,
palette.name = viridis,
border = "grey")
}
par(mfrow = c(2, 2))
plot_som_heatmap(SOM_model, PCA_results$x[,1], "Theme 1: Availability")
plot_som_heatmap(SOM_model, PCA_results$x[,2], "Theme 2: Review Score")
plot_som_heatmap(SOM_model, PCA_results$x[,3], "Theme 3: Listing Size")
plot_som_heatmap(SOM_model, PCA_results$x[,4], "Theme 4: Num of Reviews")
par(mfrow = c(1, 1))
set.seed(123)
# Calculate Total Within-Cluster Sum of Squares
wss_full <- (nrow(data_scaled) - 1) * sum(apply(data_scaled, 2, var))
for (i in 2:15) {
wss_full[i] <- sum(kmeans(data_scaled, centers = i, nstart = 20)$withinss)
}
plot(1:15, wss_full, type = "b", pch = 19,
xlab = "Number of Clusters",
ylab = "WSS",
main = "Elbow Method: Full Dataset (10,900 obs)")
