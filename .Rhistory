b_1 <- b_1*(V1_var)
round(b_1, 4) # Print it.
corr_coef_1 <- sqrt(RHO_eigen$values[1])
round(corr_coef_1, 4) # Print this.
# Calculating the correlation matrices:
A_z <- t(matrix(a_1))
B_z <- t(matrix(b_1))
# Correlation between canonical variates and measured variables:
corr_U1Z1 <- A_z%*%rho_11
corr_V1Z2 <- B_z%*%rho_22
# Print them:
corr_U1Z1
corr_V1Z2
